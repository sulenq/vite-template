{
  "name": "vite-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "eslint . && tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:watch": "tsc -p tsconfig.app.json --noEmit --watch --preserveWatchOutput",
    "verify": "npm run lint && npm run typecheck",
    "sitemap:generate": "node src/scripts/generate-sitemap.js",
    "filepath:generate": "node src/scripts/generate-file-path-header.cjs",
    "chakra:typegen": "pnpm exec chakra typegen ./src/design-system/chakra/chakra-system.ts",
    "i18n:compile": "npx @inlang/paraglide-js compile --project ./project.inlang"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.36.0",
    "@emotion/react": "^11.14.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource-variable/wix-madefor-text": "^5.2.8",
    "@internationalized/date": "^3.12.2",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tiptap/extension-font-family": "^3.27.3",
    "@tiptap/extension-highlight": "^3.27.3",
    "@tiptap/extension-link": "^3.27.3",
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/extension-subscript": "^3.27.3",
    "@tiptap/extension-superscript": "^3.27.3",
    "@tiptap/extension-text-align": "^3.27.3",
    "@tiptap/extension-text-style": "^3.27.3",
    "@tiptap/extension-underline": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "check-password-strength": "^3.0.0",
    "html-react-parser": "^6.1.3",
    "lucide-react": "^1.17.0",
    "minisearch": "^7.2.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.81.0",
    "react-icons": "^5.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@chakra-ui/cli": "^3.36.0",
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.20.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
